#pragma once
// Copy to Secret.h (gitignored) and set a random salt, e.g. `openssl rand -hex 24`.
// The web build embeds it to sign score POSTs; the Worker verifies with the same
// value (`wrangler secret put SCORE_SALT`). Without it, builds still work but the
// server rejects the (unsigned) submissions.
#define TB_SCORE_SALT "changeme"
